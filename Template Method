    }
}

class CsvReport : ReportGenerator
{
    protected override void CreateHeader(){
        Console.WriteLine("CSV");
    }

    protected override void FormatData(){
        Console.WriteLine("через запятую");
    }

    protected override void CreateBody(){
        Console.WriteLine("Создание строк CSV файла");
    }
}

class Program{
    static void Main(){
        ReportGenerator pdf = new PdfReport();
        ReportGenerator excel = new ExcelReport();
        ReportGenerator html = new HtmlReport();
        ReportGenerator csv = new CsvReport();

        Console.WriteLine("PDF отчет");
        pdf.GenerateReport();

        Console.WriteLine();

        Console.WriteLine("Excel отчет");
        excel.GenerateReport();

        Console.WriteLine();

        Console.WriteLine("HTML отчет");
        html.GenerateReport();

        Console.WriteLine();

        Console.WriteLine("CSV отчет");
        csv.GenerateReport();
    }
}
